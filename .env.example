BOT_TOKEN={{BOT_TOKEN}}
# Comma-separated Telegram admin IDs. Examples:
# ADMIN_IDS=123456789
# ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789
DATABASE_URL=sqlite+aiosqlite:///data/booking_bot.db
TIMEZONE=Europe/Moscow
DEFAULT_SLOT_STEP_MINUTES=30
BOOKING_DAYS_AHEAD=30
BOOKING_FIRST_PAGE_DAYS=14
CANCEL_BOOKING_HOURS_BEFORE=2
RESCHEDULE_BOOKING_HOURS_BEFORE=2
DEFAULT_LANGUAGE=ru
ENABLED_LANGUAGES=ru,en
SUPPORTED_LANGUAGES=ru,en
CONTACT_ADMIN_USERNAME=
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CLIENT_ID={{GOOGLE_CLIENT_ID}}
GOOGLE_CLIENT_SECRET={{GOOGLE_CLIENT_SECRET}}
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN={{GOOGLE_REFRESH_TOKEN}}
GOOGLE_CALENDAR_ID=primary
REMINDERS_ENABLED=true
CLIENT_REMINDER_1_MINUTES=1440
CLIENT_REMINDER_2_MINUTES=120
ADMIN_REMINDER_MINUTES=60
REMINDER_TEST_MODE=false
